version: '3.8'

services:
  lumis-ai:
    build: .
    container_name: lumis_ai_app
    restart: always
    ports:
      - "5001:5001"
    volumes:
      - ./backend:/app/backend
      - ./backend/instance:/app/instance
      - ./frontend:/app/frontend
    env_file:
      - ./backend/.env
    environment:
      - FLASK_ENV=production
      - MOCK_MODE=true
      - PYTHONPATH=/app/backend
