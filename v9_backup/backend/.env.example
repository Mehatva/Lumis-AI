# ─────────────────────────────────────────────────────────
# Business Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///chatbot.db

# OpenAI
OPENAI_API_KEY=sk-...

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your-page-access-token
INSTAGRAM_VERIFY_TOKEN=your-custom-verify-token
INSTAGRAM_PAGE_ID=your-instagram-page-id

# Mock / Demo Mode (set to true to skip real API calls)
MOCK_MODE=true

# Admin
ADMIN_SECRET=your-admin-secret-here
